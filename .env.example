# Скопируйте в .env и поправьте значения перед запуском: cp .env.example .env

# --- Безопасность (обязательно сменить) ---
# openssl rand -base64 42
SUPERSET_SECRET_KEY=please_generate_a_strong_random_key

# --- Стартовый dashboard (PR #5) ---
SUPERSET_DEFAULT_DASHBOARD_ID=1

# Загрузить демо-данные и примеры дашбордов при инициализации (удобно для проверки).
SUPERSET_LOAD_EXAMPLES=yes

# --- Брендинг ---
APP_NAME=Analytics

# --- Metadata DB (Postgres) ---
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_DB=superset
DATABASE_USER=superset
DATABASE_PASSWORD=superset

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Первичный администратор ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@example.com

# --- Прокси ---
PREFERRED_URL_SCHEME=http
